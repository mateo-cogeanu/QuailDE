diff --git a/lookandfeel/org.quail.masterpiece/contents/layouts/org.kde.plasma.desktop-layout.js b/lookandfeel/org.quail.masterpiece/contents/layouts/org.kde.plasma.desktop-layout.js
new file mode 100644
index 0000000..d697350
--- /dev/null
+++ b/lookandfeel/org.quail.masterpiece/contents/layouts/org.kde.plasma.desktop-layout.js
@@ -0,0 +1,19 @@
+loadTemplate("org.kde.plasma.desktop.defaultPanel")
+
+// Quail Masterpiece keeps the stock Plasma widget set, but it tunes the first
+// panel toward a denser, less effect-heavy layout for a faster daily desktop.
+var panelArray = panels();
+if (panelArray.length > 0) {
+    var panel = panelArray[0];
+    panel.location = "bottom";
+    panel.alignment = "center";
+    panel.height = 40;
+    panel.floating = false;
+    panel.opacity = "opaque";
+    panel.hiding = "none";
+}
+
+var desktopsArray = desktopsForActivity(currentActivity());
+for (var j = 0; j < desktopsArray.length; j++) {
+    desktopsArray[j].wallpaperPlugin = "org.kde.image";
+}
